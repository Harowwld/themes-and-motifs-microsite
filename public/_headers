# https://developers.cloudflare.com/workers/static-assets/headers
# https://opennext.js.org/cloudflare/caching#static-assets-caching
/_next/static/*
  Cache-Control: public,max-age=31536000,immutable

# Cache static assets with aggressive headers
*.jpg
  Cache-Control: public, max-age=31536000, immutable
*.jpeg
  Cache-Control: public, max-age=31536000, immutable
*.png
  Cache-Control: public, max-age=31536000, immutable
*.webp
  Cache-Control: public, max-age=31536000, immutable
*.avif
  Cache-Control: public, max-age=31536000, immutable
*.svg
  Cache-Control: public, max-age=31536000, immutable

# Cache API responses for instant loading
/api/image-cache/*
  Cache-Control: public, max-age=31536000, immutable
/api/image-proxy/*
  Cache-Control: public, max-age=31536000, immutable

# Enable Brotli compression for images
*.jpg
  Content-Encoding: br
*.jpeg
  Content-Encoding: br
*.png
  Content-Encoding: br
*.webp
  Content-Encoding: br
*.avif
  Content-Encoding: br

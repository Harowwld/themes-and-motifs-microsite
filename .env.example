# Connect to Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only (Admin/Bypass RLS) - NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=

# Prisma Connection (Transaction Pool)
DATABASE_URL=

# Prisma Direct Connection (Session Mode - required for migrations)
DIRECT_URL=

# Email (SMTP - Gmail, Outlook, etc.)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Upstash Redis for rate limiting (required for security hardening)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: Rate limit overrides (defaults shown)
# RATE_LIMIT_READ_PER_MINUTE=100
# RATE_LIMIT_WRITE_PER_MINUTE=20
# RATE_LIMIT_UPLOAD_PER_MINUTE=5